# ─── Server ───────────────────────────────────────────────────────────────
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────────────────
# Local Postgres (docker-compose up will start one matching this URL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/phcustomerapi

# ─── Auth ─────────────────────────────────────────────────────────────────
# 256-bit random secret. Generate with: openssl rand -base64 48
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_ISSUER=phcustomerapi
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# OTP (phone login). For now we log codes; later, wire SMS provider.
OTP_TTL_SECONDS=300
OTP_DEV_CODE=123456

# ─── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated origin allowlist
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ─── Rate limiting ────────────────────────────────────────────────────────
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=1 minute
