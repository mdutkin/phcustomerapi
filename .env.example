# Reference template for phcustomerapi env vars.
# DO NOT put real secrets in this file — copy values into .env.local
# (gitignored) or .env.${NODE_ENV}.local.
#
# Load order (later wins):
#   .env  →  .env.local  →  .env.${NODE_ENV}  →  .env.${NODE_ENV}.local

# ─── Server ───────────────────────────────────────────────────────────────
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=debug

# ─── Postgres (system of record for portal-only data) ─────────────────────
# Holds: users, otp_challenges, refresh_tokens, user_patients (link),
# refill_requests, otc_products, carts, orders, payments, threads,
# messages, audit_log. Brand-new schema we own.
# Local dev: docker-compose up will start one matching this URL.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/phcustomerapi

# ─── MSSQL / PrimeRX (read-only — patients, Rx, drugs, prescribers) ───────
# Internal host: 192.168.0.107:1433. For local dev, open an SSH tunnel
# in another terminal:
#     ssh -L 1433:192.168.0.107:1433 pha-old
# then set MSSQL_HOST=127.0.0.1 below.
MSSQL_HOST=127.0.0.1
MSSQL_PORT=1433
MSSQL_USER=replace_me
MSSQL_PASSWORD=replace_me
MSSQL_DB_340B=PharmSQL
MSSQL_DB_CONVENTIONAL=PharmSQLCONVENTIONAL
MSSQL_ENCRYPT=false
MSSQL_TRUST_SERVER_CERT=true
MSSQL_POOL_MAX=10
MSSQL_REQUEST_TIMEOUT_MS=15000

# ─── Auth ─────────────────────────────────────────────────────────────────
# 256-bit random secret. Generate with: openssl rand -base64 48
JWT_SECRET=replace_me_with_a_long_random_secret_32_chars_min
JWT_ISSUER=phcustomerapi
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# OTP (phone login). For now we log codes; later, wire SMS provider.
OTP_TTL_SECONDS=300
OTP_DEV_CODE=123456

# ─── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated origin allowlist
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ─── Rate limiting ────────────────────────────────────────────────────────
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=1 minute
